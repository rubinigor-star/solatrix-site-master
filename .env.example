# Public Vite variables. The anon key is designed to be used in the browser.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# GovMap domain-bound browser API token for RoofCheck address resolution.
# Configure the real token in the production build environment and restrict it to the live domain in GovMap API Management.
VITE_GOVMAP_API_TOKEN=YOUR_GOVMAP_DOMAIN_TOKEN

# Optional public label shown in forms.
VITE_LEAD_NOTIFICATION_EMAIL=rubin.igor@gmail.com

# Server-only secrets. Add these with `supabase secrets set`.
# Never prefix server secrets with VITE_ and never commit real values.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
RESEND_API_KEY=YOUR_RESEND_API_KEY
LEAD_NOTIFICATION_EMAIL=rubin.igor@gmail.com
LEAD_FROM_EMAIL=Solatrix Leads <leads@YOUR_VERIFIED_DOMAIN>
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_SHEETS_WEBHOOK_SECRET=YOUR_RANDOM_SHARED_SECRET
